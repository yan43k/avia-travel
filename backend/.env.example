NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://avia:avia@localhost:5432/avia_travel?schema=public"
JWT_ACCESS_SECRET=change_this_access_secret_min_16_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_min_16
ACCESS_TTL=15m
REFRESH_TTL_DAYS=14
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
COOKIE_SECURE=false
REFRESH_COOKIE_NAME=rt

# Optional SMTP (without these, emails are logged only)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Optional external weather provider
# WEATHER_API_KEY=

# Force re-seed (clears demo data): SEED_FORCE=true
