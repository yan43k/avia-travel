{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Avia Travel REST API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "render:build": "prisma generate && npm run build",
    "start:render": "prisma migrate deploy && prisma db seed && node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
